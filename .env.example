BIND_ADDR=127.0.0.1:3030
CORS_ORIGIN=https://example.com
SMTP_HOST=127.0.0.1
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=
MAIL_FROM=user@example.com
MAIL_TO=destination@example.com
NONCE_SECRET=CHANGE_ME_HEX_64
DAILY_CAP=100
PER_IP_BURST=5
PER_IP_REPLENISH_SECONDS=600
QUEUE_DIR=/var/lib/blazar/queue
RUST_LOG=blazar=info,tower_http=info
#Optional shared secret for upstream-CDN single-front-door enforcement.
#When set, requests without a matching `X-Origin-Verify` header are
#dropped silently with 204. Leave unset for local dev.
#CLOUDFRONT_VERIFY_SECRET=
